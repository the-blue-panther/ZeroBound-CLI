# ZeroBound CLI Git Ignore

# Virtual Environment
venv/
.env

# Python Cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Local Database and Logs
history.db
router.log

# Playwright / DeepSeek Profiles (Sensitive data)
profiles/
**/state.json

# User Content / Project-specific artifacts (Requested)
*.txt
!requirements.txt
*.png
*.jpg
*.jpeg
*.svg
# Allow the specific presentation PDF
!ET_project_presentation_slide.pdf

# OS specific
.DS_Store
Thumbs.db
